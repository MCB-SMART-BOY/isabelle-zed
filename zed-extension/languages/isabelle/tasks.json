[
  {
    "label": "isabelle: check current theory (process_theories)",
    "command": "isabelle",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "never",
    "args": [
      "process_theories",
      "-D",
      "$ZED_WORKTREE_ROOT"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["isabelle-check"]
  },
  {
    "label": "isabelle: build worktree session (build -D)",
    "command": "isabelle",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "never",
    "args": [
      "build",
      "-D",
      "$ZED_WORKTREE_ROOT"
    ],
    "cwd": "$ZED_WORKTREE_ROOT"
  }
]

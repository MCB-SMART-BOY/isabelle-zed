{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Isabelle Bridge NDJSON Protocol",
  "type": "object",
  "required": ["id", "type", "session", "version", "payload"],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["document.push", "document.check", "diagnostics", "markup"]
    },
    "session": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    },
    "payload": {}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "document.push" } },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["uri", "text"],
            "properties": {
              "uri": { "type": "string" },
              "text": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "document.check" } },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["uri", "version"],
            "properties": {
              "uri": { "type": "string" },
              "version": { "type": "integer" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "diagnostics" } },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["uri", "range", "severity", "message"],
              "properties": {
                "uri": { "type": "string" },
                "range": {
                  "type": "object",
                  "required": ["start", "end"],
                  "properties": {
                    "start": {
                      "type": "object",
                      "required": ["line", "col"],
                      "properties": {
                        "line": { "type": "integer" },
                        "col": { "type": "integer" }
                      },
                      "additionalProperties": false
                    },
                    "end": {
                      "type": "object",
                      "required": ["line", "col"],
                      "properties": {
                        "line": { "type": "integer" },
                        "col": { "type": "integer" }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                },
                "severity": {
                  "type": "string",
                  "enum": ["error", "warning", "info"]
                },
                "message": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "markup" } },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["uri", "offset", "info"],
            "properties": {
              "uri": { "type": "string" },
              "offset": {
                "type": "object",
                "required": ["line", "col"],
                "properties": {
                  "line": { "type": "integer" },
                  "col": { "type": "integer" }
                },
                "additionalProperties": false
              },
              "info": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ]
}
